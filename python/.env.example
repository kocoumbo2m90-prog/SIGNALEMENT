# .env example file
# Copy this to .env and fill in the values

# Flask environment
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# Database
DATABASE_URL=sqlite:///signalement.db

# Security
SECRET_KEY=change-me-in-production

# CORS
CORS_ORIGINS=*

# File uploads
MAX_UPLOAD_SIZE=500000000

# Logging
LOG_LEVEL=INFO
